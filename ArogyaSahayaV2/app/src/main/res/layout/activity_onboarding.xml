<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">
    <androidx.viewpager2.widget.ViewPager2 android:id="@+id/viewPager"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface" android:padding="16dp" android:orientation="vertical">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center" android:layout_marginBottom="16dp">
            <View android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_indicator" android:layout_marginHorizontal="4dp" android:alpha="1.0"/>
            <View android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_indicator" android:layout_marginHorizontal="4dp" android:alpha="0.3"/>
            <View android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_indicator" android:layout_marginHorizontal="4dp" android:alpha="0.3"/>
            <View android:id="@+id/dot4" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_indicator" android:layout_marginHorizontal="4dp" android:alpha="0.3"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="end">
            <Button android:id="@+id/btnSkip" android:layout_width="wrap_content" android:layout_height="52dp"
                android:text="Skip" android:textSize="15sp" android:backgroundTint="@color/surface_variant"
                android:textColor="@color/text_secondary" android:layout_marginEnd="12dp"/>
            <Button android:id="@+id/btnNext" android:layout_width="wrap_content" android:layout_height="52dp"
                android:text="Next →" android:textSize="16sp" android:backgroundTint="@color/primary"
                android:textColor="#FFFFFF" android:paddingHorizontal="28dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
