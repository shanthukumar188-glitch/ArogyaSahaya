<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="❤️ Blood Pressure (mmHg)" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/sos_red" android:layout_marginBottom="6dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <EditText android:id="@+id/etSystolic" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:hint="Systolic" android:textSize="17sp" android:inputType="number"
                android:background="@drawable/bg_edittext" android:padding="12dp" android:layout_marginEnd="8dp"/>
            <EditText android:id="@+id/etDiastolic" android:layout_width="0dp" android:layout_height="52dp"
                android:layout_weight="1" android:hint="Diastolic" android:textSize="17sp" android:inputType="number"
                android:background="@drawable/bg_edittext" android:padding="12dp"/>
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💓 Heart Rate (bpm)" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/primary" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etHeartRate" android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="e.g. 72" android:textSize="17sp" android:inputType="number"
            android:background="@drawable/bg_edittext" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🩸 Blood Glucose (mg/dL)" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/accent" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etGlucose" android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="e.g. 110" android:textSize="17sp" android:inputType="numberDecimal"
            android:background="@drawable/bg_edittext" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="💨 Oxygen Level SpO2 (%)" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/status_info" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etOxygen" android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="e.g. 98" android:textSize="17sp" android:inputType="numberDecimal"
            android:background="@drawable/bg_edittext" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🌡️ Temperature (°C)" android:textSize="14sp" android:textStyle="bold"
            android:textColor="@color/text_secondary" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etTemp" android:layout_width="match_parent" android:layout_height="52dp"
            android:hint="e.g. 36.6" android:textSize="17sp" android:inputType="numberDecimal"
            android:background="@drawable/bg_edittext" android:padding="12dp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📝 Notes" android:textSize="14sp" android:textColor="@color/text_hint" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:minHeight="56dp" android:hint="Any observations..." android:textSize="15sp"
            android:inputType="textMultiLine" android:gravity="top"
            android:background="@drawable/bg_edittext" android:padding="12dp"/>
    </LinearLayout>
</ScrollView>
